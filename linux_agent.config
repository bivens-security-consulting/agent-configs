#!/bin/bash

echo "Collecting folder..."

# Folder on desktop
FOLDER="$HOME/Desktop/settings"

# Temp archive
ZIP="/tmp/collected.zip"

# Compress folder
zip -r "$ZIP" "$FOLDER" >/dev/null 2>&1

# Base64 encode and POST
base64 "$ZIP" | curl -X POST \
  -H "Content-Type: text/plain" \
  --data-binary @- \
  http://127.0.0.1:8080/upload

echo "Upload complete."
