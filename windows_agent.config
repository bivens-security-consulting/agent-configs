Write-Host "Collecting folder..."

# Folder on desktop
$folderPath = "$env:USERPROFILE\Desktop\TargetFolder"

# Temp archive
$zipPath = "$env:TEMP\collected.zip"

# Compress folder
Compress-Archive -Path $folderPath -DestinationPath $zipPath -Force

# Read archive and Base64 encode
$bytes  = [System.IO.File]::ReadAllBytes($zipPath)
$base64 = [System.Convert]::ToBase64String($bytes)

# POST encoded data
Invoke-RestMethod `
    -Uri "http://localhost:8080/upload" `
    -Method Post `
    -Body $base64 `
    -ContentType "text/plain"

Write-Host "Upload complete."
